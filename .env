APP_NAME=Twitter-Sentiment-Analysis
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
ENABLE_DOCS=true

SECRET_KEY=my_super_secret_key_twitter_sentiment_analysis_123456789

CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

MODEL_DIR=ml/saved_models
DISTILBERT_MODEL_PATH=ml/saved_models/distilbert
BILSTM_MODEL_PATH=ml/saved_models/bilstm/model.keras
BILSTM_TOKENIZER_PATH=ml/saved_models/bilstm/tokenizer.pkl
DEFAULT_MODEL=distilbert

MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=Twitter-Sentiment-Analysis

LOG_LEVEL=INFO
LOG_FORMAT=console

HOST=0.0.0.0
PORT=8000
WORKERS=1